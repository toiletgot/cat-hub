stopBtn.MouseButton1Click:Connect(function() clearObjects() end)

-- 入力設定復活
local function makeInput(name, default, key)
    local f = Instance.new("Frame", scroll); f.Size = UDim2.new(0, 140, 0, 45); f.BackgroundTransparency = 1
    local l = Instance.new("TextLabel", f); l.Size = UDim2.new(1, 0, 0, 15); l.Text = name; l.TextColor3 = Color3.new(0.8,0.8,0.8); l.BackgroundTransparency = 1; l.Font = "Code"; l.TextSize = 12
    local b = Instance.new("TextBox", f); b.Size = UDim2.new(1, 0, 0, 25); b.Position = UDim2.new(0,0,0,15); b.BackgroundColor3 = Color3.fromRGB(50,50,50); b.TextColor3 = Color3.new(1,1,1); b.Text = tostring(default); b.Font = "Code"; b.ClearTextOnFocus = false; Instance.new("UICorner", b)
    b.FocusLost:Connect(function() settings[key] = tonumber(b.Text) or settings[key] end)
end
makeInput("速度", settings.speed, "speed"); makeInput("広がり", settings.width, "width"); makeInput("高さ", settings.height, "height")

-- ドラッグ
local dragging, dragStart, startPos
dragBtn.InputBegan:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then dragging = true; dragStart = input.Position; startPos = main.Position end end)
UIS.InputChanged:Connect(function(input) if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then local delta = input.Position - dragStart; main.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y) end end)
UIS.InputEnded:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then dragging = false end end)

-- キャラクター接続
local function connectCharacter(char)
    if not char then return end
    char:WaitForChild("HumanoidRootPart")
    for _, v in ipairs(char:GetChildren()) do
        if v:IsA("BasePart") then
            v.Touched:Connect(function(hit) if mode ~= "None" then registerPart(hit) end end)
        end
    end
end
player.CharacterAdded:Connect(connectCharacter)
if player.Character then connectCharacter(player.Character) end

-- --- メインループ ---
local timeCounter = 0
RunService.Heartbeat:Connect(function()
    if mode == "None" then return end
    local hrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    
    timeCounter = timeCounter + settings.speed
    local currentParts = {}
    for o in pairs(objectData) do table.insert(currentParts, o) end
    local total = #currentParts

    for i, o in ipairs(currentParts) do
        if o and o.Parent and o:FindFirstChild("SyncForce") then
            local data = objectData[o]
            local targetPos
            
            if mode == "MagicCircle" then
                local angle = (timeCounter * 2) + (i / total * math.pi * 2)
                local s = settings.width / 2
                local res = 0.2
                local x = math.sign(math.cos(angle)) * math.pow(math.abs(math.cos(angle)), res) * s
                local z = math.sign(math.sin(angle)) * math.pow(math.abs(math.sin(angle)), res) * s
                local tilt = CFrame.Angles(math.rad(11.5), 0, math.rad(11.5))
                targetPos = hrp.Position + Vector3.new(0, settings.height, 0) + (tilt * Vector3.new(x, 0, z))
                o.SyncGyro.CFrame = hrp.CFrame * tilt * CFrame.Angles(0, angle, 0)
            elseif mode == "Orbit" then
                local angle = timeCounter + (i * (math.pi * 2 / total))
                targetPos = hrp.Position + Vector3.new(math.cos(angle) * settings.width, settings.height, math.sin(angle) * settings.width)
                o.SyncGyro.CFrame = CFrame.new(o.Position, hrp.Position)
            elseif mode == "Ghost" then
                local t = timeCounter + data.seed
                targetPos = hrp.Position + Vector3.new(math.sin(t * 0.7) * settings.width, math.cos(t * 0.5) * (settings.width * 0.5) + settings.height, math.sin(t * 0.3) * settings.width)
                o.SyncGyro.CFrame = o.SyncGyro.CFrame * CFrame.Angles(0.05, 0.05, 0.05)
            elseif mode == "Manji" then
                local b = (i - 1) % 4
                local a = (b * math.pi / 2) + (timeCounter * 1.5)
                local sIdx = math.floor((i - 1) / 4)
                local r = math.min(1, sIdx / (math.max(1, total/4) * 0.6 + 0.1))
                targetPos = hrp.Position + Vector3.new(math.cos(a) * (r * settings.width), settings.height, math.sin(a) * (r * settings.width))
                o.SyncGyro.CFrame = CFrame.new(Vector3.zero, Vector3.new(math.cos(a), 0, math.sin(a)))
            elseif mode == "Divine" then
                local a = (i / total) * math.pi * 2 + (timeCounter * 0.5)
                targetPos = hrp.Position + Vector3.new(math.cos(a) * settings.width, settings.height + math.sin(timeCounter + i) * 0.5, math.sin(a) * settings.width)
                o.SyncGyro.CFrame = CFrame.new(o.Position, hrp.Position + Vector3.new(0, 10, 0))
            elseif mode == "Geometry" then
                local n = 12 
                local sA = timeCounter * 1.5 + data.phase
                local lA = ((i - 1) % n / n) * math.pi * 2 + (timeCounter * 0.2)
                targetPos = hrp.Position + Vector3.new(math.cos(lA) * settings.width + math.cos(sA) * 5, settings.height, math.sin(lA) * settings.width + math.sin(sA) * 5)
                o.SyncGyro.CFrame = CFrame.new(o.Position, targetPos + Vector3.new(math.cos(lA), 0, math.sin(lA)))
            end
            
            o.SyncForce.Velocity = (targetPos - o.Position) * 18
            if math.random() > 0.95 then pcall(function() o:SetNetworkOwner(player) end) end
        else
            objectData[o] = nil; hoveringObjects[o] = nil
        end
    end
end)
