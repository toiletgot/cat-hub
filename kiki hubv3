makeBtn("Ghost", "幽霊", Color3.fromRGB(40, 40, 80))
makeBtn("Divine", "神聖", Color3.fromRGB(80, 80, 40))
makeBtn("Manji", "卍", Color3.fromRGB(100, 40, 100))
