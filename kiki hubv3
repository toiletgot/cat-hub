--[[
    kiki hub - FULL STABLE COMPLETE
    すべてのボタンを復活させ、死亡時のリセットバグを修正した完全版です。
]]

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UIS = game:GetService("UserInputService")
local player = Players.LocalPlayer

local mode = "None" 
local hoveringObjects = {}
local objectData = {}

local settings = {
    speed = 0.03,   
    width = 18,     
    height = 5      
}

-- --- パーツ物理管理 ---
local function clearObjects()
    for o in pairs(hoveringObjects) do
        pcall(function()
            if o and o.Parent then
                o.CanCollide = true
                if o:FindFirstChild("SyncForce") then o.SyncForce:Destroy() end
                if o:FindFirstChild("SyncGyro") then o.SyncGyro:Destroy() end
            end
        end)
    end
    hoveringObjects = {}; objectData = {}
end

local function registerPart(part)
    if not part:IsA("BasePart") or part.Anchored then return end
    if player.Character and part:IsDescendantOf(player.Character) then return end
    if hoveringObjects[part] then return end 

    hoveringObjects[part] = true
    objectData[part] = { 
        seed = math.random() * 100,
        phase = math.random() * math.pi * 2,
        offset = math.random()
    }
    
    if not part:FindFirstChild("SyncForce") then
        local bv = Instance.new("BodyVelocity")
        bv.Name = "SyncForce"; bv.MaxForce = Vector3.new(1,1,1)*1e6; bv.P = 1500; bv.Velocity = Vector3.new(0,0,0); bv.Parent = part
        local bg = Instance.new("BodyGyro")
        bg.Name = "SyncGyro"; bg.MaxTorque = Vector3.new(1,1,1)*1e6; bg.P = 4000; bg.D = 500; bg.CFrame = part.CFrame; bg.Parent = part
    end
    
    part.CanCollide = false
    pcall(function() part:SetNetworkOwner(player) end)
end

-- --- UI構築 (ResetOnSpawn = false で保護) ---
local oldGui = player:WaitForChild("PlayerGui"):FindFirstChild("KikiHubGui")
if oldGui then oldGui:Destroy() end

local gui = Instance.new("ScreenGui", player.PlayerGui)
gui.Name = "KikiHubGui"
gui.ResetOnSpawn = false 

local main = Instance.new("Frame", gui)
main.Size = UDim2.new(0, 160, 0, 300); main.Position = UDim2.new(1, -170, 1, -320); main.BackgroundColor3 = Color3.fromRGB(20, 20, 20); Instance.new("UICorner", main)

local dragBtn = Instance.new("TextLabel", main)
dragBtn.Size = UDim2.new(1, 0, 0, 25); dragBtn.Text = "kiki hub"; dragBtn.BackgroundColor3 = Color3.fromRGB(60, 60, 60); dragBtn.TextColor3 = Color3.new(1, 1, 1); dragBtn.Font = "Code"; dragBtn.TextScaled = true; dragBtn.Active = true

local scroll = Instance.new("ScrollingFrame", main)
scroll.Size = UDim2.new(1, 0, 1, -25); scroll.Position = UDim2.new(0, 0, 0, 25); scroll.CanvasSize = UDim2.new(0, 0, 0, 600); scroll.BackgroundTransparency = 1; scroll.ScrollBarThickness = 4
local uiList = Instance.new("UIListLayout", scroll); uiList.Padding = UDim.new(0, 5); uiList.HorizontalAlignment = "Center"

local buttons = {}
local function makeBtn(id, text, color)
    local b = Instance.new("TextButton", scroll)
    b.Size = UDim2.new(0, 140, 0, 30); b.Text = text .. ": 無効"; b.BackgroundColor3 = color; b.TextColor3 = Color3.new(1,1,1); b.Font = "Code"; Instance.new("UICorner", b)
    buttons[id] = {btn = b, defaultColor = color, label = text}
    
    b.MouseButton1Click:Connect(function()
        mode = (mode == id) and "None" or id
        for btnId, data in pairs(buttons) do
            if mode == btnId then
                data.btn.Text = data.label .. ": 有効"; data.btn.BackgroundColor3 = Color3.fromRGB(200, 200, 200); data.btn.TextColor3 = Color3.new(0,0,0)
            else
                data.btn.Text = data.label .. ": 無効"; data.btn.BackgroundColor3 = data.defaultColor; data.btn.TextColor3 = Color3.new(1,1,1)
            end
        end
    end)
end

-- ボタン復活
makeBtn("Orbit", "回転", Color3.fromRGB(80, 40, 40))
