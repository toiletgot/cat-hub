-- 目の前に置く機能
place.MouseButton1Click:Connect(function()
    local hrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    local basePos = hrp.Position + (hrp.CFrame.LookVector * 10)
    local i = 0
    for o in pairs(hoveringObjects) do
        if o and o.Parent then
            o.CanCollide = true
            o.CFrame = CFrame.new(basePos + hrp.CFrame.RightVector * (i * 4 - 8))
            i = i + 1
        end
    end
    hoveringObjects = {}
end)

throw.MouseButton1Click:Connect(function()
    for o in pairs(hoveringObjects) do if o then o.CanCollide = true o.AssemblyLinearVelocity = camera.CFrame.LookVector * flingPower end end
    for o in pairs(frozenObjects) do if o then o.Anchored = false o.AssemblyLinearVelocity = camera.CFrame.LookVector * flingPower end end
    hoveringObjects, frozenObjects = {}, {}
end)

freezeGrab.MouseButton1Click:Connect(function() for o in pairs(hoveringObjects) do if o then frozenObjects[o] = {pos = o.Position} hoveringObjects[o] = nil end end end)
clearFreeze.MouseButton1Click:Connect(function() for o in pairs(frozenObjects) do if o then o.Anchored = false end end frozenObjects = {} end)

-- メインループ
loop = RunService.RenderStepped:Connect(function(dt)
    local hrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    if enabled then
        local t = getTarget()
        if t then hoveringObjects[t] = true t.CanCollide = false t.Massless = true end
    end

    totalRotation += math.rad(orbitSpeed) * dt
    if spinXEnabled then totalSpinX += math.rad(spinXSpeed) * dt end
    if spinYEnabled then totalSpinY += math.rad(spinYSpeed) * dt end

    local objs = {}
    for o in pairs(hoveringObjects) do
        if o and o.Parent then table.insert(objs, o) else hoveringObjects[o] = nil end
    end

    for i, o in ipairs(objs) do
        local phase = (totalRotation * 0.1 + (i / #objs)) % 1
        local targetPos
        
        if tornadoEnabled then
            local vCycle = math.sin(phase * math.pi * 2) 
            local yPos = liftHeight + (vCycle * (tornadoHeight / 2))
            local spreadMult = 1 + (vCycle * (tornadoSpread - 1))
            local dynRadius = radius * spreadMult
            local angle = phase * math.pi * 2 * tornadoTightness
            targetPos = hrp.Position + Vector3.new(math.cos(angle) * dynRadius, yPos, math.sin(angle) * dynRadius)
        elseif rotateEnabled then
            local angle = (totalRotation + (i / #objs) * math.pi * 2)
            targetPos = hrp.Position + Vector3.new(math.cos(angle) * radius, liftHeight, math.sin(angle) * radius)
        else
            targetPos = hrp.Position + Vector3.new(0, liftHeight, 0)
        end

        -- パーツ自体の回転（X/Y回転がONのとき反映）
        local currentRot = CFrame.Angles(totalSpinX, totalSpinY, 0)
        o.CFrame = o.CFrame:Lerp(CFrame.new(targetPos) * currentRot, 0.3)
        o.AssemblyLinearVelocity = Vector3.zero
    end

    for o, data in pairs(frozenObjects) do
        if o and o.Parent then o.Anchored = true o.CFrame = CFrame.new(data.pos) else frozenObjects[o] = nil end
    end
end)
