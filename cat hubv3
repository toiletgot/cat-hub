local function btn(t)
    local b = Instance.new("TextButton", scroll)
    b.Size = UDim2.new(0, 100, 0, 18)
    b.Text = t
    b.TextSize = 9
    b.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
    b.TextColor3 = Color3.fromRGB(255, 255, 255)
    Instance.new("UICorner", b)
