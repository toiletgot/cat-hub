local RunService = game:GetService("RunService")
local UIS = game:GetService("UserInputService")

local player = Players.LocalPlayer
local camera = workspace.CurrentCamera

-- 状態管理
local enabled, rotateEnabled, spinXEnabled, spinYEnabled, tornadoEnabled = false, false, false, false, false
local hoveringObjects = {}
local frozenObjects = {}

local totalRotation, totalSpinX, totalSpinY = 0, 0, 0
local loop

-- 基本設定
local radius = 8
local orbitSpeed = 50
local spinXSpeed = 80
local spinYSpeed = 80
local flingPower = 350
local liftHeight = 12

-- 竜巻設定
local tornadoHeight = 20
local tornadoSpread = 1.5
local tornadoTightness = 3

-- ターゲット取得
local function getTarget()
    local origin = camera.CFrame.Position
    local dir = camera.CFrame.LookVector * 50
    local rp = RaycastParams.new()
    rp.FilterDescendantsInstances = {player.Character}
    rp.FilterType = Enum.RaycastFilterType.Exclude
    local r = workspace:Raycast(origin, dir, rp)
    if r and r.Instance then
        local i = r.Instance
        if Players:GetPlayerFromCharacter(i.Parent) then return end
        if i:IsA("Terrain") then return end
        if i.Name:lower():find("baseplate") then return end
        if i.Anchored and i.Size.Magnitude > 15 then return end
        return i
    end
end

