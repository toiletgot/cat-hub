throw.MouseButton1Click:Connect(function()
    local look = camera.CFrame.LookVector
    for o in pairs(hoveringObjects) do if o then removeCoolEffects(o); o.CanCollide = true; o.AssemblyLinearVelocity = look * flingPower end end
    for o in pairs(frozenObjects) do if o then o.Anchored = false; o.AssemblyLinearVelocity = look * flingPower end end
    hoveringObjects, frozenObjects = {}, {}; deployPoint = nil
end)

