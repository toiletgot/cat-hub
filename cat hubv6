-- --- メインループ ---
loop = RunService.RenderStepped:Connect(function(dt)
    local character = player.Character; local hrp = character and character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    if enabled then
        local t = getTarget()
        if t and not hoveringObjects[t] and not frozenObjects[t] then addCoolEffects(t); t.CanCollide = false; t.Massless = true end
    end
    local currentTime = tick(); totalRotation += math.rad(orbitSpeed) * dt; magicCircleRotation += math.rad(magicCircleRotationSpeed) * dt; sandstormTime += dt; spiritDanceTime += dt * spiritDanceSpeed; manjiRotation += math.rad(manjiRotationSpeed) * dt; squareRotation += math.rad(squareRotationSpeed) * dt; omenTime += dt
    if spinXEnabled then totalSpinX += math.rad(spinXSpeed) * dt end; if spinYEnabled then totalSpinY += math.rad(spinYSpeed) * dt end
    local objs = {}; for o in pairs(hoveringObjects) do if o and o.Parent then table.insert(objs, o) else hoveringObjects[o] = nil end end
    local centerPos = deployPoint or (hrp.Position - Vector3.new(0, 3, 0))
    if magicCircleEnabled and not deployPoint then updateVisualPentagram(centerPos, radius) end

    for i, o in ipairs(objs) do
        local phase = (totalRotation * 0.1 + (i / #objs)) % 1; local targetPos; local currentObjRot = CFrame.Angles(totalSpinX, totalSpinY, 0); local currentLerp = lerpSpeed 
        if omenEnabled then
            local seed = objectSeeds[o] or {distMod = 0, heightMod = 0, rotAxis = Vector3.new(0,1,0), phase = 0}
            local angle = (omenTime * (orbitSpeed/10)) + (i / #objs) * math.pi * 2
            local curDist = omenBaseRadius + seed.distMod + (math.sin(omenTime + seed.phase) * (omenSpread/3))
            local curHeight = omenBaseHeight + seed.heightMod + (math.cos(omenTime * 0.7 + seed.phase) * omenVerticalWave)
            targetPos = hrp.Position + Vector3.new(math.cos(angle) * curDist, curHeight, math.sin(angle) * curDist)
            currentObjRot = CFrame.fromAxisAngle(seed.rotAxis, omenTime * omenRotationSpeed); currentLerp = omenLerpSpeed 
        elseif squareEnabled then
            local totalObjs = #objs; local manjiCenter = hrp.Position + Vector3.new(0, liftHeight, 0); local rotationCFrame = CFrame.Angles(0, squareRotation, 0)
            if totalObjs == 1 then targetPos = manjiCenter
            else
                local t = (currentTime * (squareRotationSpeed / 100) + (i / totalObjs)) % 1
                local function getSquarePos(param, pRadius)
                    local p = param * 4; local side = math.floor(p); local f = p - side; local size = pRadius 
                    if side == 0 then return Vector3.new(size, 0, -size + f * size * 2) elseif side == 1 then return Vector3.new(size - f * size * 2, 0, size) elseif side == 2 then return Vector3.new(-size, 0, size - f * size * 2) else return Vector3.new(-size + f * size * 2, 0, -size) end
                end
                targetPos = manjiCenter + (rotationCFrame * getSquarePos(t, squareRadius))
            end
            currentLerp = 0.5 
        elseif manjiEnabled then
            local totalObjs = #objs; local manjiCenter = hrp.Position + Vector3.new(0, liftHeight, 0); local rotationCFrame = CFrame.Angles(0, manjiRotation, 0)
            if totalObjs > 0 then
                if i == 1 then targetPos = manjiCenter
                else
                    local currentI = i - 1; local totalArmObjs = totalObjs - 1; local objsPerArm = math.floor(totalArmObjs / 4); local extraObjs = totalArmObjs % 4; local indexInArm, armIndex = 0, 0; local objsAccumulated = 0
                    for a = 0, 3 do local oArm = objsPerArm + (a < extraObjs and 1 or 0); if currentI <= objsAccumulated + oArm then armIndex = a; indexInArm = currentI - objsAccumulated; break end; objsAccumulated = objsAccumulated + oArm end
                    local armAngle = ({0, math.pi/2, math.pi, math.pi*1.5})[armIndex + 1]; local seg1 = math.ceil((objsPerArm + (armIndex < extraObjs and 1 or 0)) * 0.5)
                    local localPos; if indexInArm <= seg1 then localPos = Vector3.new(math.cos(armAngle), 0, math.sin(armAngle)) * ((indexInArm / seg1) * (manjiRadius * 0.6))
                    else local index2 = indexInArm - seg1; local seg2 = (objsPerArm + (armIndex < extraObjs and 1 or 0)) - seg1; local cp = Vector3.new(math.cos(armAngle), 0, math.sin(armAngle)) * (manjiRadius * 0.6); local aa2 = armAngle - math.pi/2; localPos = cp + Vector3.new(math.cos(aa2), 0, math.sin(aa2)) * ((index2 / seg2) * (manjiRadius * 0.4)) end
                    targetPos = manjiCenter + (rotationCFrame * localPos)
                end
            else targetPos = hrp.Position + Vector3.new(0, liftHeight, 0) end
            currentLerp = 0.5 
        elseif spiritDanceEnabled then
            local oSeed = i * 200; local noiseX = math.noise(spiritDanceTime, oSeed, 0); local noiseY = math.noise(oSeed, spiritDanceTime, 0); local noiseZ = math.noise(0, oSeed, spiritDanceTime)
            targetPos = hrp.Position + Vector3.new(noiseX * spiritDanceRadius * 2, spiritDanceHeight + (noiseY * 10), noiseZ * spiritDanceRadius * 2); currentObjRot = CFrame.Angles(spiritDanceTime * 0.5 + noiseX * 5, spiritDanceTime * 0.7 + noiseY * 5, spiritDanceTime * 0.3 + noiseZ * 5); currentLerp = 0.1
        elseif sandstormEnabled then
            local oSeed = i * 100; local angle = (sandstormOrbitSpeed * sandstormTime + (i / #objs) * math.pi * 2); local nX = math.noise(sandstormTime * 10, 0, oSeed); local nY = math.noise(sandstormTime * 10, oSeed, 0); local nZ = math.noise(oSeed, sandstormTime * 10, 0)
            targetPos = hrp.Position + Vector3.new(math.cos(angle) * radius, liftHeight, math.sin(angle) * radius) + Vector3.new(nX, nY, nZ) * sandstormScatter; currentObjRot = CFrame.Angles(sandstormTime * 50, sandstormTime * 50, sandstormTime * 50); currentLerp = 0.5
        elseif magicCircleEnabled then
            local function getPentPos(t, pr)
                local pIdx = math.floor(t * 5) % 5 + 1; local order = {1, 3, 5, 2, 4}; local a1 = (order[pIdx]-1) * (math.pi * 2 / 5) + magicCircleRotation; local a2 = (order[(pIdx % 5) + 1]-1) * (math.pi * 2 / 5) + magicCircleRotation
                return (Vector3.new(math.cos(a1), 0, math.sin(a1)) * pr):Lerp(Vector3.new(math.cos(a2), 0, math.sin(a2)) * pr, (t * 5) % 1)
            end
            local t = (phase + (i/ #objs)) % 1; local pulse = math.sin(currentTime * magicPulseSpeed + i) * magicPulseStrength
            targetPos = centerPos + getPentPos(t, radius) + Vector3.new(0, pulse + 1, 0); currentObjRot = CFrame.new(targetPos, centerPos + getPentPos((t + 0.01) % 1, radius) + Vector3.new(0, pulse + 1, 0)).Rotation * currentObjRot
        elseif auraEnabled then
            local angle = (totalRotation * 2.5 + (i / #objs) * math.pi * 2); targetPos = hrp.Position + Vector3.new(math.cos(angle) * (radius * 0.7 + (math.cos(currentTime * 2 + i) * 1.5)), liftHeight + (math.sin(currentTime * auraVerticalSpeed + (i * auraRandomness)) * auraVerticalStrength), math.sin(angle) * (radius * 0.7 + (math.cos(currentTime * 2 + i) * 1.5)))
        elseif sunEnabled then
            local angle = (totalRotation + (i / #objs) * math.pi * 2); targetPos = hrp.Position + Vector3.new(math.cos(angle) * (radius + (math.sin(currentTime * sunPulsationSpeed) * sunPulsationStrength)), liftHeight, math.sin(angle) * (radius + (math.sin(currentTime * sunPulsationSpeed) * sunPulsationStrength)))
        elseif wingEnabled then
            local side = (i % 2 == 0) and 1 or -1; local index = math.ceil(i / 2)
            local flapAngle = 0
            if wingFlapEnabled then -- ★羽ばたき判定
                flapAngle = math.sin(currentTime * wingFlapSpeed - (index * wingWaveDelay)) * wingFlapStrength 
            end
            targetPos = (hrp.CFrame * CFrame.new((wingSideSpacing * index * (1.0 + (index * 0.1))) * side, (wingVertSpacing * index), wingBackOffset)).Position
            currentObjRot = hrp.CFrame.Rotation * CFrame.Angles(0, math.rad(side * 30) + math.rad(side * 10) * index, 0) * CFrame.Angles(math.rad(flapAngle * 25), 0, math.rad(side * flapAngle * 10)) * CFrame.Angles(totalSpinX, totalSpinY, 0); currentLerp = 0.4 
        elseif tornadoEnabled then
            local tObjs = #objs; local cone = (i / tObjs); local dRad = tornadoBottomRadius + (cone * (tornadoTopRadius - tornadoBottomRadius)); local angle = (totalRotation * 2) + ((i / tObjs) * tornadoHeight * tornadoTightness)
            targetPos = hrp.Position + Vector3.new(math.cos(angle) * dRad, cone * tornadoHeight, math.sin(angle) * dRad); currentLerp = 0.3 
        elseif rotateEnabled then
            local angle = (totalRotation + (i / #objs) * math.pi * 2); targetPos = hrp.Position + Vector3.new(math.cos(angle) * radius, liftHeight, math.sin(angle) * radius)
        else
            targetPos = (hrp.CFrame * CFrame.new(math.sin(i)*2, liftHeight, 5)).Position
        end
        o.CFrame = o.CFrame:Lerp(CFrame.new(targetPos) * currentObjRot, currentLerp); o.AssemblyLinearVelocity, o.AssemblyAngularVelocity = Vector3.zero, Vector3.zero
    end
    for o, data in pairs(frozenObjects) do if o and o.Parent then o.Anchored = true; o.CFrame = CFrame.new(data.pos) else frozenObjects[o] = nil end end
end)
