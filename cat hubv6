local function createTrailForPart(part, data)
    if data.Trail then data.Trail:Destroy() end
    if data.AAttachment0 then data.AAttachment0:Destroy() end
    if data.AAttachment1 then data.AAttachment1:Destroy() end

    local a0 = Instance.new("Attachment", part)
    a0.Position = Vector3.new(0, part.Size.Y/2, 0)
    local a1 = Instance.new("Attachment", part)
    a1.Position = Vector3.new(0, -part.Size.Y/2, 0)
    
    local trail = Instance.new("Trail", part)
    trail.Attachment0 = a0
    trail.Attachment1 = a1
    trail.Color = ColorSequence.new(part.Color, Color3.new(0,0,0))
    trail.Lifetime = 0.5
    trail.LightEmission = 1
    trail.Transparency = NumberSequence.new({NumberSequenceKeypoint.new(0, 0), NumberSequenceKeypoint.new(1, 1)})
    trail.WidthScale = NumberSequence.new({NumberSequenceKeypoint.new(0, 1), NumberSequenceKeypoint.new(1, 0)})
    
    data.Trail = trail
    data.AAttachment0 = a0
    data.AAttachment1 = a1
end

local function addCoolEffects(part)
    if not hoveringObjects[part] then
        hoveringObjects[part] = {
            Color = part.Color,
            Material = part.Material,
            Trail = nil,
            AAttachment0 = nil,
            AAttachment1 = nil
        }
        part.Material = Enum.Material.Neon
        if manjiEnabled then part.Color = manjiColor
        elseif squareEnabled then part.Color = squareColor
        elseif sandstormEnabled then part.Color = sandNeonColors[math.random(1, #sandNeonColors)]
        elseif spiritDanceEnabled then part.Color = spiritNeonColors[math.random(1, #spiritNeonColors)] 
        else part.Color = coolNeonColors[math.random(1, #coolNeonColors)] end
        if trailEnabled then createTrailForPart(part, hoveringObjects[part]) end
        objectSeeds[part] = {
            distMod = math.random(-omenSpread, omenSpread),
            heightMod = math.random(-omenSpread/2, omenSpread/2),
            rotAxis = Vector3.new(math.random(-10, 10), math.random(-10, 10), math.random(-10, 10)).Unit,
            phase = math.random() * math.pi * 2
        }
    end
end

local function removeCoolEffects(part)
    local data = hoveringObjects[part]
    if data then
        if part.Parent then
            part.Color = data.Color
            part.Material = data.Material
            if data.Trail then data.Trail:Destroy() end
            if data.AAttachment0 then data.AAttachment0:Destroy() end
            if data.AAttachment1 then data.AAttachment1:Destroy() end
        end
        hoveringObjects[part] = nil
        objectSeeds[part] = nil
    end
end

local function updateAllObjectColors()
    for part, data in pairs(hoveringObjects) do
        if part and part.Parent then
            if manjiEnabled then part.Color = manjiColor
            elseif squareEnabled then part.Color = squareColor
            elseif sandstormEnabled then part.Color = sandNeonColors[math.random(1, #sandNeonColors)]
            elseif spiritDanceEnabled then part.Color = spiritNeonColors[math.random(1, #spiritNeonColors)] 
            else part.Color = coolNeonColors[math.random(1, #coolNeonColors)] end
            if data.Trail then data.Trail.Color = ColorSequence.new(part.Color, Color3.new(0,0,0)) end
        end
    end
end

local function toggleAllTrails(on)
    for part, data in pairs(hoveringObjects) do
        if on then createTrailForPart(part, data)
        else
            if data.Trail then data.Trail:Destroy(); data.Trail = nil end
            if data.AAttachment0 then data.AAttachment0:Destroy(); data.AAttachment0 = nil end
            if data.AAttachment1 then data.AAttachment1:Destroy(); data.AAttachment1 = nil end
        end
    end
end

local function clearVisualPentagram()
    for _, p in pairs(magicParts) do p:Destroy() end
    magicParts = {}
end

local function updateVisualPentagram(pos, pRadius)
    clearVisualPentagram()
    if not showVisualPentagram or not magicCircleEnabled then return end
    local function createLine(p1, p2)
        local dist = (p1 - p2).Magnitude
        local part = Instance.new("Part")
        part.Anchored = true; part.CanCollide = false; part.Material = Enum.Material.Neon
        part.Color = Color3.fromRGB(100, 100, 255); part.Size = Vector3.new(0.2, 0.2, dist)
        part.CFrame = CFrame.new(p1:Lerp(p2, 0.5), p2); part.Parent = workspace
        table.insert(magicParts, part); part.Transparency = 1
        Tweens:Create(part, TweenInfo.new(0.5), {Transparency = 0.3}):Play()
    end
    local points = {}
    for i = 1, 5 do
        local angle = (i-1) * (math.pi * 2 / 5) + magicCircleRotation
        table.insert(points, pos + Vector3.new(math.cos(angle) * pRadius, 0, math.sin(angle) * pRadius))
    end
    createLine(points[1], points[3]); createLine(points[3], points[5]); createLine(points[5], points[2]); createLine(points[2], points[4]); createLine(points[4], points[1])
end

local function getTarget()
    local origin = camera.CFrame.Position
    local dir = camera.CFrame.LookVector * 60
    local rp = RaycastParams.new()
    rp.FilterDescendantsInstances = {player.Character}
    rp.FilterType = Enum.RaycastFilterType.Exclude
    local r = workspace:Raycast(origin, dir, rp)
    if r and r.Instance then
        local i = r.Instance
        if Players:GetPlayerFromCharacter(i.Parent) then return end
        if i:IsA("Terrain") or i.Name:lower():find("baseplate") then return end
        if i.Anchored and i.Size.Magnitude > 20 then return end
        return i
    end
end

