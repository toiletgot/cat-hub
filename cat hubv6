local deployPoint = nil
place.MouseButton1Click:Connect(function()
    local hrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    deployPoint = hrp.Position + (hrp.CFrame.LookVector * (radius + 2))
    if magicCircleEnabled then updateVisualPentagram(deployPoint - Vector3.new(0, 3, 0), radius) end
