-- ================= メインループ =================
loopConnection = RunService.RenderStepped:Connect(function(dt)
    local hrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    if enabled then
        local t = getTarget()
        if t and t:IsA("BasePart") then
            hoveringObjects[t] = true
            t.CanCollide = false
            t.Massless = true
        end
    end

    totalRotation += math.rad(orbitSpeed) * dt
    if spinEnabled then totalSpinX += math.rad(spinXSpeed) * dt end
    if spin2Enabled then totalSpinY += math.rad(spinYSpeed) * dt end

    local objects = {}
    for o in pairs(hoveringObjects) do
        if o and o.Parent then table.insert(objects,o) else hoveringObjects[o]=nil end
    end

    local center = hrp.Position + Vector3.new(0,liftHeight,0)
    for i,o in ipairs(objects) do
        local angle = totalRotation + (i/#objects) * math.pi*2
        local pos = rotateEnabled and center + Vector3.new(math.cos(angle)*radius,0,math.sin(angle)*radius) or center
        o.CFrame = CFrame.new(pos) * CFrame.Angles(totalSpinX,totalSpinY,0)
        o.AssemblyLinearVelocity = Vector3.zero
        o.AssemblyAngularVelocity = Vector3.zero
    end
end)
