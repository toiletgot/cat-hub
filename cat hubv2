-- ================= UI生成関数 =================
local function makeBtn(text)
    local b = Instance.new("TextButton", scroll)
    b.Size = UDim2.new(0,130,0,22)
    b.BackgroundColor3 = Color3.fromRGB(60,60,60)
    b.TextColor3 = Color3.fromRGB(255,255,255)
    b.Text = text
    b.TextSize = 11
    Instance.new("UICorner", b).CornerRadius = UDim.new(0,4)
    return b
end

local function makeInp(name,val)
    local f = Instance.new("Frame", scroll)
    f.Size = UDim2.new(0,130,0,28)
    f.BackgroundTransparency = 1

    local l = Instance.new("TextLabel", f)
    l.Size = UDim2.new(0.6,0,1,0)
    l.Text = name
    l.TextColor3 = Color3.fromRGB(200,200,200)
    l.TextSize = 10
    l.BackgroundTransparency = 1

    local t = Instance.new("TextBox", f)
    t.Size = UDim2.new(0.4,0,0.8,0)
    t.Position = UDim2.new(0.6,0,0.1,0)
    t.Text = tostring(val)
    t.BackgroundColor3 = Color3.fromRGB(45,45,45)
    t.TextColor3 = Color3.fromRGB(255,255,255)
    t.TextSize = 10
    Instance.new("UICorner", t).CornerRadius = UDim.new(0,4)
    return t
end

