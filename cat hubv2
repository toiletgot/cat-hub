-- ================= ターゲット取得 =================
local function getTarget()
    local origin = camera.CFrame.Position
    local dir = camera.CFrame.LookVector * 50
    local rp = RaycastParams.new()
    rp.FilterDescendantsInstances = {player.Character}
    rp.FilterType = Enum.RaycastFilterType.Exclude

    local result = workspace:Raycast(origin, dir, rp)
    if result and result.Instance then
        local inst = result.Instance
        if Players:GetPlayerFromCharacter(inst.Parent) then return nil end
        if inst:IsA("Terrain") then return nil end
        if inst.Name:lower():find("floor") or inst.Name:lower():find("baseplate") then return nil end
        if inst.Anchored and inst.Size.Magnitude > 15 then return nil end
        return inst
    end
end

