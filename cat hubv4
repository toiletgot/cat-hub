-- タスクspawn検出ループは削除されました（掴み連携のため）

-- --- メインループ ---
loop = RunService.RenderStepped:Connect(function(dt)
    local character = player.Character
    local hrp = character and character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    -- 「掴む」がONの時だけ、ターゲットを検知して掴む
    if enabled then
        local t = getTarget()
        -- 掴んでいない、かつ固定されていないオブジェクトであれば掴む
        if t and not hoveringObjects[t] and not frozenObjects[t] then 
            addCoolEffects(t) -- エフェクト追加（このの中でモードに応じた色になる）
            t.CanCollide = false
            t.Massless = true 
        end
    end

    local currentTime = tick()
    totalRotation += math.rad(orbitSpeed) * dt
    magicCircleRotation += math.rad(magicCircleRotationSpeed) * dt
    sandstormTime += dt 
    spiritDanceTime += dt * spiritDanceSpeed -- 精霊の舞用の時間
    
    if spinXEnabled then totalSpinX += math.rad(spinXSpeed) * dt end
    if spinYEnabled then totalSpinY += math.rad(spinYSpeed) * dt end

    local objs = {}
    for o in pairs(hoveringObjects) do if o and o.Parent then table.insert(objs, o) else hoveringObjects[o] = nil end end

    -- 基準点
    local centerPos = deployPoint or (hrp.Position - Vector3.new(0, 3, 0))
    if magicCircleEnabled and not deployPoint then updateVisualPentagram(centerPos, radius) end

    for i, o in ipairs(objs) do
        local phase = (totalRotation * 0.1 + (i / #objs)) % 1 
        local targetPos
        local currentObjRot = CFrame.Angles(totalSpinX, totalSpinY, 0) 
        local currentLerp = lerpSpeed -- デフォルトの追従速度

        if spiritDanceEnabled then
            -- 精霊の舞（SPIRIT DANCE）のロジック
            -- 「掴む」で掴んだオブジェクトに対して適用される
            local objectSeed = i * 200 -- オブジェクトごとの乱数シード

            -- Perlinノイズを使って、無造作で滑らかな3次元の動きを作る
            local noiseX = math.noise(spiritDanceTime, objectSeed, 0) -- -0.5 ～ 0.5 くらい
            local noiseY = math.noise(objectSeed, spiritDanceTime, 0)
            local noiseZ = math.noise(0, objectSeed, spiritDanceTime)

            -- ノイズを半径倍して、プレイヤーの周りに配置
            local offsetX = noiseX * spiritDanceRadius * 2 -- 横の広がり
            local offsetZ = noiseZ * spiritDanceRadius * 2
            local offsetY = spiritDanceHeight + (noiseY * 10) -- 縦の揺らぎ（基本高さ + 上下5ポンド）

            targetPos = hrp.Position + Vector3.new(offsetX, offsetY, offsetZ)

            -- 自転もゆっくりと幻想的に
            currentObjRot = CFrame.Angles(
                spiritDanceTime * 0.5 + noiseX * 5,
                spiritDanceTime * 0.7 + noiseY * 5,
                spiritDanceTime * 0.3 + noiseZ * 5
            )

            -- ゆったりと動かしたいので、Lerpを少し遅く
            currentLerp = 0.1

        elseif sandstormEnabled then
            local objectSeed = i * 100 
            local angle = (sandstormOrbitSpeed * sandstormTime + (i / #objs) * math.pi * 2)
            
            local noiseX = math.noise(sandstormTime * sandstormTurbulence, 0, objectSeed)
            local noiseY = math.noise(sandstormTime * sandstormTurbulence, objectSeed, 0)
            local noiseZ = math.noise(objectSeed, sandstormTime * sandstormTurbulence, 0)
            
            local scatterOffset = Vector3.new(noiseX, noiseY, noiseZ) * sandstormScatter
            local basePos = hrp.Position + Vector3.new(math.cos(angle) * radius, liftHeight, math.sin(angle) * radius)
            
            targetPos = basePos + scatterOffset
            currentObjRot = CFrame.Angles(sandstormTime * 50 + noiseX * 10, sandstormTime * 50 + noiseY * 10, sandstormTime * 50 + noiseZ * 10)
            currentLerp = 0.5

        elseif magicCircleEnabled then
            local starPoints = 5
            local function getPentagramPos(t, pRadius)
                local pIdx = math.floor(t * starPoints) % starPoints + 1
                local order = {1, 3, 5, 2, 4}
                local a1 = (order[pIdx]-1) * (math.pi * 2 / starPoints) + magicCircleRotation
                local a2 = (order[(pIdx % starPoints) + 1]-1) * (math.pi * 2 / starPoints) + magicCircleRotation
                local p1 = Vector3.new(math.cos(a1), 0, math.sin(a1)) * pRadius
                local p2 = Vector3.new(math.cos(a2), 0, math.sin(a2)) * pRadius
                return p1:Lerp(p2, (t * starPoints) % 1)
            end
            local t = (phase + (i/ #objs)) % 1
            local pulse = math.sin(currentTime * magicPulseSpeed + i) * magicPulseStrength
            targetPos = centerPos + getPentagramPos(t, radius) + Vector3.new(0, pulse + 1, 0)
            
            local nextT = (t + 0.01) % 1
            currentObjRot = CFrame.new(targetPos, centerPos + getPentagramPos(nextT, radius) + Vector3.new(0, pulse + 1, 0)).Rotation * currentObjRot

        elseif auraEnabled then
            local angle = (totalRotation * 2.5 + (i / #objs) * math.pi * 2) 
            local yOffset = liftHeight + (math.sin(currentTime * auraVerticalSpeed + (i * auraRandomness)) * auraVerticalStrength)
            local curRad = radius * 0.7 + (math.cos(currentTime * 2 + i) * 1.5)
            targetPos = hrp.Position + Vector3.new(math.cos(angle) * curRad, yOffset, math.sin(angle) * curRad)
            
        elseif sunEnabled then
            local angle = (totalRotation + (i / #objs) * math.pi * 2)
            local dynamicRadius = radius + (math.sin(currentTime * sunPulsationSpeed) * sunPulsationStrength)
            targetPos = hrp.Position + Vector3.new(math.cos(angle) * dynamicRadius, liftHeight, math.sin(angle) * dynamicRadius)
            
        elseif wingEnabled then
            -- 自然な翼の動き
            local side = (i % 2 == 0) and 1 or -1 -- 右か左か
            local index = math.ceil(i / 2) -- 内側から何番目か
            
            -- 時間経過による羽ばたき（内側から外側へ伝わるウェーブ）
            local flapSine = math.sin(currentTime * wingFlapSpeed - (index * wingWaveDelay))
            local flapAngle = flapSine * wingFlapStrength -- 上下の角度調整

            -- 1. 座標の計算 (プレイヤーに対する相対位置)
            local spacingFactor = 1.0 + (index * 0.1) -- 外側ほど少し間隔を広く
            local posX = (wingSideSpacing * index * spacingFactor) * side
            local posY = (wingVertSpacing * index) -- 縦方向の位置調整
            local posZ = wingBackOffset -- 背中からの距離

            targetPos = (hrp.CFrame * CFrame.new(posX, posY, posZ)).Position

            -- 2. 角度の計算 (自然な羽ばたきの回転)
            local baseAngleY = math.rad(side * 30) -- 内側の羽を30度外へ向ける
            local incrementalAngleY = math.rad(side * 10) * index -- 外側ほどさらに外へ向ける
            
            local currentFlapAngle = flapAngle -- 羽ばたき角度

            local wingRotation = hrp.CFrame.Rotation * CFrame.Angles(0, baseAngleY + incrementalAngleY, 0) -- 基本の向き
            local flapRotation = CFrame.Angles(math.rad(currentFlapAngle * 25), 0, math.rad(side * currentFlapAngle * 10)) -- 自然な羽ばたきのひねり

            currentObjRot = wingRotation * flapRotation * CFrame.Angles(totalSpinX, totalSpinY, 0)
            
            currentLerp = 0.4 -- Lerpを速く

        elseif tornadoEnabled then
            local vCycle = math.sin(phase * math.pi * 2) 
            local angle = phase * math.pi * 2 * tornadoTightness + totalRotation
            local dynRad = radius * 0.5 * (1 + (vCycle * (tornadoSpread - 1)))
            targetPos = hrp.Position + Vector3.new(math.cos(angle) * dynRad, liftHeight + (vCycle * tornadoHeight/2), math.sin(angle) * dynRad)
            
        elseif rotateEnabled then
            local angle = (totalRotation + (i / #objs) * math.pi * 2)
            targetPos = hrp.Position + Vector3.new(math.cos(angle) * radius, liftHeight, math.sin(angle) * radius)
            
        else
            targetPos = (hrp.CFrame * CFrame.new(math.sin(i)*2, liftHeight, 5)).Position
        end

        o.CFrame = o.CFrame:Lerp(CFrame.new(targetPos) * currentObjRot, currentLerp)
        o.AssemblyLinearVelocity = Vector3.zero
        o.AssemblyAngularVelocity = Vector3.zero
    end

    for o, data in pairs(frozenObjects) do if o and o.Parent then o.Anchored = true; o.CFrame = CFrame.new(data.pos) else frozenObjects[o] = nil end end
end)
