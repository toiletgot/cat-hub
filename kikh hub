--[[
    kiki hub - 完全版 v1
    卍モードを「×」ではなく、先端を曲げた「卍」の形に強化。
]]

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UIS = game:GetService("UserInputService")
local player = Players.LocalPlayer

-- 状態管理
local mode = "None" 
local hoveringObjects = {}
local objectData = {}

local settings = {
    range = 3,      
    speed = 0.05,   
    width = 15,     
    height = 5      
}

-- --- 同期・解除関数 ---
local function clearObjects()
    for o in pairs(hoveringObjects) do
        pcall(function()
            if o and o.Parent then
                o.CanCollide = true
                if o:FindFirstChild("SyncForce") then o.SyncForce:Destroy() end
                if o:FindFirstChild("SyncGyro") then o.SyncGyro:Destroy() end
            end
        end)
    end
    hoveringObjects = {}; objectData = {}
    mode = "None"
end

local function syncToServer(part)
    if not part:IsA("BasePart") or part.Anchored then return end
    if not part:FindFirstChild("SyncForce") then
        local bv = Instance.new("BodyVelocity")
        bv.Name = "SyncForce"; bv.MaxForce = Vector3.new(1,1,1)*1e6; bv.Velocity = Vector3.new(0,0,0); bv.Parent = part
        local bg = Instance.new("BodyGyro")
        bg.Name = "SyncGyro"; bg.MaxTorque = Vector3.new(1,1,1)*1e6; bg.CFrame = part.CFrame; bg.Parent = part
    end
    pcall(function() part:SetNetworkOwner(player) end)
end

-- --- UI作成 ---
local gui = Instance.new("ScreenGui", player:WaitForChild("PlayerGui"))
gui.ResetOnSpawn = false
local main = Instance.new("Frame", gui)
main.Size = UDim2.new(0, 160, 0, 260); main.Position = UDim2.new(1, -170, 1, -280); main.BackgroundColor3 = Color3.fromRGB(20, 20, 20); Instance.new("UICorner", main)

local dragBtn = Instance.new("TextLabel", main)
dragBtn.Size = UDim2.new(1, 0, 0, 25); dragBtn.Text = "kiki hub"; dragBtn.BackgroundColor3 = Color3.fromRGB(60, 60, 60); dragBtn.TextColor3 = Color3.new(1, 1, 1); dragBtn.Font = "Code"; dragBtn.TextScaled = true; dragBtn.Active = true

local scroll = Instance.new("ScrollingFrame", main)
scroll.Size = UDim2.new(1, 0, 1, -25); scroll.Position = UDim2.new(0, 0, 0, 25); scroll.CanvasSize = UDim2.new(0, 0, 0, 480); scroll.BackgroundTransparency = 1; scroll.ScrollBarThickness = 4
local uiList = Instance.new("UIListLayout", scroll); uiList.Padding = UDim.new(0, 5); uiList.HorizontalAlignment = "Center"

local function makeBtn(text, color)
    local b = Instance.new("TextButton", scroll)
    b.Size = UDim2.new(0, 140, 0, 30); b.Text = text; b.BackgroundColor3 = color; b.TextColor3 = Color3.new(1,1,1); b.Font = "Code"; Instance.new("UICorner", b)
    return b
end

local orbitBtn = makeBtn("回転: 無効", Color3.fromRGB(80, 40, 40))
local ghostBtn = makeBtn("幽霊: 無効", Color3.fromRGB(40, 40, 80))
local divineBtn = makeBtn("神聖: 無効", Color3.fromRGB(80, 80, 40))
local tornadoBtn = makeBtn("竜巻: 無効", Color3.fromRGB(40, 80, 80))
local manjiBtn = makeBtn("卍: 無効", Color3.fromRGB(100, 40, 100))
local stopBtn = makeBtn("停止", Color3.fromRGB(150, 50, 50))

local function makeInput(name, default)
    local f = Instance.new("Frame", scroll); f.Size = UDim2.new(0, 140, 0, 45); f.BackgroundTransparency = 1
    local l = Instance.new("TextLabel", f); l.Size = UDim2.new(1, 0, 0, 15); l.Text = name; l.TextColor3 = Color3.new(0.8,0.8,0.8); l.BackgroundTransparency = 1; l.Font = "Code"; l.TextSize = 12
    local b = Instance.new("TextBox", f); b.Size = UDim2.new(1, 0, 0, 25); b.Position = UDim2.new(0,0,0,15); b.BackgroundColor3 = Color3.fromRGB(50,50,50); b.TextColor3 = Color3.new(1,1,1); b.Text = tostring(default); b.Font = "Code"; b.ClearTextOnFocus = false; Instance.new("UICorner", b)
    return b
end

local speedIn = makeInput("速度", settings.speed)
local widthIn = makeInput("広がり", settings.width)
local heightIn = makeInput("高さ", settings.height)

local function updateUI()
    orbitBtn.Text = (mode == "Orbit") and "回転: 有効" or "回転: 無効"
    ghostBtn.Text = (mode == "Ghost") and "幽霊: 有効" or "幽霊: 無効"
    divineBtn.Text = (mode == "Divine") and "神聖: 有効" or "神聖: 無効"
    tornadoBtn.Text = (mode == "Tornado") and "竜巻: 有効" or "竜巻: 無効"
    manjiBtn.Text = (mode == "Manji") and "卍: 有効" or "卍: 無効"
end

orbitBtn.MouseButton1Click:Connect(function() mode = (mode == "Orbit") and "None" or "Orbit"; if mode == "None" then clearObjects() end updateUI() end)
ghostBtn.MouseButton1Click:Connect(function() mode = (mode == "Ghost") and "None" or "Ghost"; if mode == "None" then clearObjects() end updateUI() end)
divineBtn.MouseButton1Click:Connect(function() mode = (mode == "Divine") and "None" or "Divine"; if mode == "None" then clearObjects() end updateUI() end)
tornadoBtn.MouseButton1Click:Connect(function() mode = (mode == "Tornado") and "None" or "Tornado"; if mode == "None" then clearObjects() end updateUI() end)
manjiBtn.MouseButton1Click:Connect(function() mode = (mode == "Manji") and "None" or "Manji"; if mode == "None" then clearObjects() end updateUI() end)
stopBtn.MouseButton1Click:Connect(function() clearObjects(); updateUI() end)

speedIn.FocusLost:Connect(function() settings.speed = tonumber(speedIn.Text) or settings.speed end)
widthIn.FocusLost:Connect(function() settings.width = tonumber(widthIn.Text) or settings.width end)
heightIn.FocusLost:Connect(function() settings.height = tonumber(heightIn.Text) or settings.height end)

-- ドラッグ
local dragging, dragStart, startPos
dragBtn.InputBegan:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then dragging = true; dragStart = input.Position; startPos = main.Position end end)
UIS.InputChanged:Connect(function(input) if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then local delta = input.Position - dragStart; main.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y) end end)
UIS.InputEnded:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then dragging = false end end)

-- --- メインループ ---
local timeCounter = 0
RunService.Heartbeat:Connect(function()
    if mode == "None" then return end
    local hrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    timeCounter = timeCounter + settings.speed

    local parts = workspace:GetPartBoundsInRadius(hrp.Position, settings.range)
    for _, p in ipairs(parts) do
        if p:IsA("BasePart") and not p.Anchored and not p:IsDescendantOf(player.Character) and not hoveringObjects[p] then
            hoveringObjects[p] = true; syncToServer(p)
            objectData[p] = { seed = math.random() * 100, angleOffset = math.rad(math.random(360)) }
            p.CanCollide = false
        end
    end

    local count, total = 0, 0
    for _ in pairs(objectData) do total = total + 1 end

    for o, data in pairs(objectData) do
        if o and o.Parent and o:FindFirstChild("SyncForce") then
            count = count + 1
            local targetPos
            
            if mode == "Orbit" then
                local angle = timeCounter + data.angleOffset
                targetPos = hrp.Position + Vector3.new(math.cos(angle) * settings.width, settings.height, math.sin(angle) * settings.width)
                o.SyncGyro.CFrame = CFrame.new(o.Position, hrp.Position)
            elseif mode == "Ghost" then
                local t = timeCounter + data.seed
                targetPos = hrp.Position + Vector3.new(math.sin(t * 0.7) * settings.width, math.cos(t * 0.5) * (settings.width * 0.5) + settings.height, math.sin(t * 0.3) * settings.width)
                o.SyncGyro.CFrame = o.SyncGyro.CFrame * CFrame.Angles(0.1, 0.1, 0.1)
            elseif mode == "Divine" then
                local angle = (count / total) * math.pi * 2 + (timeCounter * 0.5)
                targetPos = hrp.Position + Vector3.new(math.cos(angle) * settings.width, settings.height + math.sin(timeCounter + count) * 0.5, math.sin(angle) * settings.width)
                o.SyncGyro.CFrame = CFrame.new(o.Position, hrp.Position + Vector3.new(0, 10, 0))
            elseif mode == "Tornado" then
                local angle = timeCounter * 2 + (count * 0.5)
                local yRatio = (math.sin(timeCounter + count * 0.3) + 1) / 2
                local yOffset = yRatio * (settings.height * 2)
                local radius = (yRatio * 0.8 + 0.2) * settings.width 
                targetPos = hrp.Position + Vector3.new(math.cos(angle) * radius, yOffset, math.sin(angle) * radius)
                o.SyncGyro.CFrame = CFrame.Angles(0, angle, 0)
            elseif mode == "Manji" then
                -- ★卍強化ロジック
                local branch = count % 4 -- 4つの腕に分ける
                local baseAngle = (branch * math.pi / 2) + (timeCounter * 1.5)
                local segmentIndex = math.floor(count / 4)
                local segmentTotal = math.max(1, total / 4)
                
                -- 直線の長さ
                local length = (segmentIndex / segmentTotal) * settings.width
                local xOffset = math.cos(baseAngle) * length
                local zOffset = math.sin(baseAngle) * length
                
                -- 腕の半分以降を90度曲げる
                if segmentIndex > (segmentTotal / 2) then
                    local bendLength = (segmentIndex - segmentTotal / 2) * 2
                    xOffset = xOffset + math.cos(baseAngle + math.pi/2) * bendLength
                    zOffset = zOffset + math.sin(baseAngle + math.pi/2) * bendLength
                end
                
                targetPos = hrp.Position + Vector3.new(xOffset, settings.height, zOffset)
                o.SyncGyro.CFrame = CFrame.new(o.Position, o.Position + Vector3.new(math.cos(baseAngle), 0, math.sin(baseAngle)))
            end
            
            o.SyncForce.Velocity = (targetPos - o.Position) * 25
        else
            hoveringObjects[o] = nil; objectData[o] = nil
        end
    end
end)
