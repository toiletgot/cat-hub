-- --- ループ・イベント ---
RunService.Stepped:Connect(function()
    if player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
        local hrp = player.Character.HumanoidRootPart
        local hum = player.Character:FindFirstChildOfClass("Humanoid")
        
        -- Fly
        if settings.flyEnabled then
            flyBV.Parent = hrp; flyBG.Parent = hrp; flyBG.CFrame = camera.CFrame
            if hum.MoveDirection.Magnitude > 0 then
                flyBV.Velocity = camera.CFrame.LookVector * settings.flySpeed
            else
                flyBV.Velocity = Vector3.new(0, 0.1, 0)
            end
            hum.PlatformStand = true
        else
            flyBV.Parent = nil; flyBG.Parent = nil
            if hum then
                hum.PlatformStand = false
                hum.WalkSpeed = settings.speedEnabled and settings.customSpeed or 16
                hum.JumpPower = settings.jumpEnabled and settings.customJump or 50
            end
        end
    end
    camera.FieldOfView = settings.fov
end)

UserInputService.JumpRequest:Connect(function()
    if settings.infJump and player.Character then
        local hum = player.Character:FindFirstChildOfClass("Humanoid")
        if hum then hum:ChangeState(Enum.HumanoidStateType.Jumping) end
    end
end)

-- 物理計算（モード別）
local timeCounter = 0
RunService.Heartbeat:Connect(function()
    if mode == "None" then return end
    local target = Players:FindFirstChild(selectedTargetName)
    local hrp = target and target.Character and target.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    timeCounter = timeCounter + settings.speed
    local currentParts = {}
    for o in pairs(objectData) do table.insert(currentParts, o) end
    local total = #currentParts
    for i, o in ipairs(currentParts) do
        if o and o.Parent and o:FindFirstChild("SyncForce") then
            local data = objectData[o]; local targetPos
            if mode == "Orbit" then
                local a = timeCounter + (i * (math.pi * 2 / total))
                targetPos = hrp.Position + Vector3.new(math.cos(a) * settings.width, settings.height, math.sin(a) * settings.width)
                o.SyncGyro.CFrame = CFrame.new(o.Position, hrp.Position)
            elseif mode == "MagicCircle" then
                local a = (timeCounter * 2) + (i / total * math.pi * 2)
                targetPos = hrp.Position + Vector3.new(math.cos(a) * (settings.width/2), settings.height, math.sin(a) * (settings.width/2))
                o.SyncGyro.CFrame = hrp.CFrame * CFrame.Angles(0, a, 0)
            elseif mode == "Ghost" then
                local t = timeCounter + data.seed
                targetPos = hrp.Position + Vector3.new(math.sin(t * 0.7) * settings.width, math.cos(t * 0.5) * (settings.width * 0.5) + settings.height, math.sin(t * 0.3) * settings.width)
                o.SyncGyro.CFrame = o.SyncGyro.CFrame * CFrame.Angles(0.05, 0.05, 0.05)
            elseif mode == "Manji" then
                local a = ((i-1)%4 * math.pi/2) + (timeCounter * 1.5)
                local r = math.min(1, math.floor((i-1)/4) / (total/4 * 0.6 + 0.1))
                targetPos = hrp.Position + Vector3.new(math.cos(a) * (r * settings.width), settings.height, math.sin(a) * (r * settings.width))
                o.SyncGyro.CFrame = CFrame.new(Vector3.zero, Vector3.new(math.cos(a), 0, math.sin(a)))
            elseif mode == "Divine" then
                local a = (i / total) * math.pi * 2 + (timeCounter * 0.5)
                targetPos = hrp.Position + Vector3.new(math.cos(a) * settings.width, settings.height + math.sin(timeCounter + i) * 0.5, math.sin(a) * settings.width)
                o.SyncGyro.CFrame = CFrame.new(o.Position, hrp.Position + Vector3.new(0, 10, 0))
            elseif mode == "Geometry" then
                local lA = ((i-1)%12 / 12) * math.pi * 2 + (timeCounter * 0.2)
                local sA = timeCounter * 1.5 + data.phase
                targetPos = hrp.Position + Vector3.new(math.cos(lA) * settings.width + math.cos(sA) * 5, settings.height, math.sin(lA) * settings.width + math.sin(sA) * 5)
                o.SyncGyro.CFrame = CFrame.new(o.Position, targetPos)
            end
            if targetPos then
                o.SyncForce.Velocity = (targetPos - o.Position) * 18
                if math.random() > 0.9 then pcall(function() o:SetNetworkOwner(player) end) end
            end
        else objectData[o] = nil; hoveringObjects[o] = nil end
    end
end)

-- キャラクター自動登録
local function setupCharacter(char)
    char:WaitForChild("HumanoidRootPart")
    for _, v in ipairs(char:GetChildren()) do
        if v:IsA("BasePart") then
            v.Touched:Connect(function(hit) if mode ~= "None" then registerPart(hit) end end)
        end
    end
end
for _, p in ipairs(Players:GetPlayers()) do if p.Character then setupCharacter(p.Character) end p.CharacterAdded:Connect(setupCharacter) end
Players.PlayerAdded:Connect(function(p) p.CharacterAdded:Connect(setupCharacter) end)

