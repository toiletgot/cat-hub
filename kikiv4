--[[
    kiki hub x Orion Lib - 調整範囲拡大版
    【変更点】
    - 回転速度: 最大 0.5 (超高速回転が可能)
    - 広がり: 最大 500 (マップ全体に広がるレベル)
    - 高さ: 最大 500 / 最小 -500 (超高空・地底まで調整可能)
]]

local OrionLib = loadstring(game:HttpGet("https://raw.githubusercontent.com/BlizTBr/scripts/main/Orion%20X"))()
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local player = Players.LocalPlayer

-- --- 内部変数 ---
local mode = "None"
local hoveringObjects = {}
local objectData = {}
local settings = {
    speed = 0.03,
    width = 18,
    height = 5,
    speedEnabled = false,
    jumpEnabled = false,
    customSpeed = 100,
    customJump = 150
}

-- --- 物理管理 ---
local function clearObjects()
    for o in pairs(hoveringObjects) do
        pcall(function()
            if o and o.Parent then
                o.CanCollide = true
                if o:FindFirstChild("SyncForce") then o.SyncForce:Destroy() end
                if o:FindFirstChild("SyncGyro") then o.SyncGyro:Destroy() end
            end
        end)
    end
    hoveringObjects = {}; objectData = {}
end

local function registerPart(part)
    if not part:IsA("BasePart") or part.Anchored then return end
    if player.Character and part:IsDescendantOf(player.Character) then return end
    if hoveringObjects[part] then return end 

    hoveringObjects[part] = true
    objectData[part] = { seed = math.random() * 100, phase = math.random() * math.pi * 2 }
    
    local bv = Instance.new("BodyVelocity")
    bv.Name = "SyncForce"; bv.MaxForce = Vector3.new(1,1,1)*1e7; bv.P = 3000; bv.Parent = part
    local bg = Instance.new("BodyGyro")
    bg.Name = "SyncGyro"; bg.MaxTorque = Vector3.new(1,1,1)*1e7; bg.P = 5000; bg.D = 500; bg.Parent = part
    
    part.CanCollide = false
    pcall(function() part:SetNetworkOwner(player) end)
end

-- --- UI構築 ---
local Window = OrionLib:MakeWindow({Name = "kiki hub - MEGA ADJUST", IntroText = "数値上限解放完了"})

local MainTab = Window:MakeTab({ Name = "能力", Icon = "rbxassetid://4483345998" })
local AdjustTab = Window:MakeTab({ Name = "調整 (拡張版)", Icon = "rbxassetid://4483345998" })
local MiscTab = Window:MakeTab({ Name = "身体設定", Icon = "rbxassetid://4483345998" })

-- 能力選択
MainTab:AddDropdown({
    Name = "モード選択",
    Default = "None",
    Options = {"None", "回転", "魔法陣", "幽霊", "神聖", "卍", "幾何学の輪"},
    Callback = function(Value)
        local map = {["None"]="None", ["回転"]="Orbit", ["魔法陣"]="MagicCircle", ["幽霊"]="Ghost", ["神聖"]="Divine", ["卍"]="Manji", ["幾何学の輪"]="Geometry"}
        mode = map[Value] or "None"
        if mode == "None" then clearObjects() end
    end
})
MainTab:AddButton({ Name = "全パーツ解除", Callback = function() clearObjects() end })

-- --- 【修正】数値の上限を解放したスライダー ---
AdjustTab:AddSlider({
    Name = "回転速度 (Speed)",
    Min = 0.01,
    Max = 0.5, -- 以前の約3倍以上
    Default = 0.03,
    Increment = 0.01,
    Callback = function(V) settings.speed = V end
})

AdjustTab:AddSlider({
    Name = "広がり (Width)",
    Min = 0,
    Max = 500, -- 巨大な円を描けるように
    Default = 18,
    Increment = 1,
    Callback = function(V) settings.width = V end
})

AdjustTab:AddSlider({
    Name = "高さ (Height)",
    Min = -500, -- 地底深くまで
    Max = 500,  -- はるか上空まで
    Default = 5,
    Increment = 1,
    Callback = function(V) settings.height = V end
})

-- 身体設定
MiscTab:AddToggle({ Name = "高速移動", Default = false, Callback = function(V) settings.speedEnabled = V end })
MiscTab:AddToggle({ Name = "高ジャンプ", Default = false, Callback = function(V) settings.jumpEnabled = V end })
MiscTab:AddSlider({ Name = "移動速度設定", Min = 16, Max = 1000, Default = 100, Increment = 1, Callback = function(V) settings.customSpeed = V end })
MiscTab:AddSlider({ Name = "ジャンプ力設定", Min = 50, Max = 1000, Default = 150, Increment = 1, Callback = function(V) settings.customJump = V end })

-- --- ループ処理 ---
player.CharacterAdded:Connect(function(char)
    char:WaitForChild("HumanoidRootPart")
    for _, v in ipairs(char:GetChildren()) do
        if v:IsA("BasePart") then
            v.Touched:Connect(function(hit) if mode ~= "None" then registerPart(hit) end end)
        end
    end
end)

RunService.Stepped:Connect(function()
    local hum = player.Character and player.Character:FindFirstChildOfClass("Humanoid")
    if hum then
        hum.WalkSpeed = settings.speedEnabled and settings.customSpeed or 16
        if settings.jumpEnabled then
            hum.UseJumpPower = true; hum.JumpPower = settings.customJump
        else
            hum.JumpPower = 50; hum.JumpHeight = 7.2
        end
    end
end)

local timeCounter = 0
RunService.Heartbeat:Connect(function()
    if mode == "None" then return end
    local hrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    
    timeCounter = timeCounter + settings.speed
    local currentParts = {}
    for o in pairs(objectData) do table.insert(currentParts, o) end
    local total = #currentParts

    for i, o in ipairs(currentParts) do
        if o and o.Parent and o:FindFirstChild("SyncForce") then
            local data = objectData[o]
            local targetPos
            
            -- ロジックはFULL STABLE版を100%継承
            if mode == "MagicCircle" then
                local angle = (timeCounter * 2) + (i / total * math.pi * 2)
                local s = settings.width / 2; local res = 0.2
                local x = math.sign(math.cos(angle)) * math.pow(math.abs(math.cos(angle)), res) * s
                local z = math.sign(math.sin(angle)) * math.pow(math.abs(math.sin(angle)), res) * s
                local tilt = CFrame.Angles(math.rad(11.5), 0, math.rad(11.5))
                targetPos = hrp.Position + Vector3.new(0, settings.height, 0) + (tilt * Vector3.new(x, 0, z))
                o.SyncGyro.CFrame = hrp.CFrame * tilt * CFrame.Angles(0, angle, 0)
            elseif mode == "Orbit" then
                local angle = timeCounter + (i * (math.pi * 2 / total))
                targetPos = hrp.Position + Vector3.new(math.cos(angle) * settings.width, settings.height, math.sin(angle) * settings.width)
                o.SyncGyro.CFrame = CFrame.new(o.Position, hrp.Position)
            elseif mode == "Ghost" then
                local t = timeCounter + data.seed
                targetPos = hrp.Position + Vector3.new(math.sin(t * 0.7) * settings.width, math.cos(t * 0.5) * (settings.width * 0.5) + settings.height, math.sin(t * 0.3) * settings.width)
                o.SyncGyro.CFrame = o.SyncGyro.CFrame * CFrame.Angles(0.05, 0.05, 0.05)
            elseif mode == "Manji" then
                local b = (i - 1) % 4; local a = (b * math.pi / 2) + (timeCounter * 1.5)
                local r = math.min(1, math.floor((i-1)/4) / (math.max(1, total/4) * 0.6 + 0.1))
                targetPos = hrp.Position + Vector3.new(math.cos(a) * (r * settings.width), settings.height, math.sin(a) * (r * settings.width))
                o.SyncGyro.CFrame = CFrame.new(Vector3.zero, Vector3.new(math.cos(a), 0, math.sin(a)))
            elseif mode == "Divine" then
                local a = (i / total) * math.pi * 2 + (timeCounter * 0.5)
                targetPos = hrp.Position + Vector3.new(math.cos(a) * settings.width, settings.height + math.sin(timeCounter + i) * 0.5, math.sin(a) * settings.width)
                o.SyncGyro.CFrame = CFrame.new(o.Position, hrp.Position + Vector3.new(0, 10, 0))
            elseif mode == "Geometry" then
                local n = 12; local sA = timeCounter * 1.5 + data.phase; local lA = ((i - 1) % n / n) * math.pi * 2 + (timeCounter * 0.2)
                targetPos = hrp.Position + Vector3.new(math.cos(lA) * settings.width + math.cos(sA) * 5, settings.height, math.sin(lA) * settings.width + math.sin(sA) * 5)
                o.SyncGyro.CFrame = CFrame.new(o.Position, targetPos + Vector3.new(math.cos(lA), 0, math.sin(lA)))
            end
            
            if targetPos then o.SyncForce.Velocity = (targetPos - o.Position) * 18 end
            if math.random() > 0.95 then pcall(function() o:SetNetworkOwner(player) end) end
        else
            objectData[o] = nil; hoveringObjects[o] = nil
        end
    end
end)

OrionLib:Init()
